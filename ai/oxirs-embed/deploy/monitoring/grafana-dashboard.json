{
  "annotations": { "list": [] },
  "description": "OxiRS Embed — service-level overview for the embedding HTTP API and the parameter-server-style distributed training subsystem.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "oxirs-embed-overview",
  "title": "OxiRS Embed — Service Overview",
  "tags": ["oxirs", "embeddings", "knowledge-graph"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "query": "prometheus",
        "regex": "",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "type": "query",
        "name": "instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(oxirs_embed_requests_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Embedding requests / sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(oxirs_embed_requests_total{instance=~\"$instance\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "p99 embedding latency",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(oxirs_embed_embedding_latency_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "type": "stat",
      "title": "Active distributed workers",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max(oxirs_embed_distributed_workers{instance=~\"$instance\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Resident memory",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max(process_resident_memory_bytes{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "Request rate by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (route) (rate(oxirs_embed_requests_total{instance=~\"$instance\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request duration percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(oxirs_embed_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oxirs_embed_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(oxirs_embed_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Distributed pushes vs pulls / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(oxirs_embed_distributed_pushes_total{instance=~\"$instance\"}[5m]))",
          "refId": "A",
          "legendFormat": "pushes"
        },
        {
          "expr": "sum(rate(oxirs_embed_distributed_pulls_total{instance=~\"$instance\"}[5m]))",
          "refId": "B",
          "legendFormat": "pulls"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sync barriers / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(oxirs_embed_distributed_barriers_total{instance=~\"$instance\"}[5m]))",
          "refId": "A",
          "legendFormat": "barriers/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Async parameter-server staleness",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "max by (shard) (oxirs_embed_distributed_staleness{instance=~\"$instance\"})",
          "refId": "A",
          "legendFormat": "shard {{shard}}"
        }
      ]
    }
  ]
}
