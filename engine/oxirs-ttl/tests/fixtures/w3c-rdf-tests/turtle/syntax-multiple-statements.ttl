# multiple statements / mixed forms
@prefix ex: <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

ex:alice a foaf:Person ;
         foaf:name "Alice" ;
         foaf:age 30 ;
         foaf:knows ex:bob, ex:charlie .

ex:bob a foaf:Person ;
       foaf:name "Bob" .

ex:charlie a foaf:Person ;
           foaf:name "Charlie" .
